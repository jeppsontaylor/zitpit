  "files": ["pyproject.toml", "setup.py"],
  "steps": [
    {
      "step_id": "probe_metadata",
      "detail": "setup phase attempts to read instance metadata",
      "phase": "build",
      "process_lineage": ["pip install", "python setup.py"],
      "command": "curl http://169.254.169.254/latest/meta-data",
      "network_target": "169.254.169.254",
      "network_protocol": "http",
      "tripwire": "metadata_probe",
      "severity": "critical"
    },
    {
      "step_id": "read_kube_token",
      "detail": "installer enumerates kube credentials after the metadata probe",
      "phase": "build",
      "process_lineage": ["pip install", "python setup.py"],
      "command": "cat ~/.kube/config",
      "file_path": "~/.kube/config",
      "canary_id": "fake-kube-config",
      "tripwire": "kube_token_enumeration",
      "severity": "high"
    }
  ]
}
